{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://priis.local/schemas/airfield_registry.schema.json",
  "title": "Skywatcher PR Airfield Registry Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "facility_id",
    "facility_type",
    "name",
    "municipio",
    "lat",
    "lon",
    "geometry_status",
    "access_status",
    "source_tier",
    "source_ref",
    "confidence",
    "review_status"
  ],
  "properties": {
    "facility_id": {"type": "string", "minLength": 1},
    "facility_type": {"type": "string", "enum": ["airport", "airstrip", "heliport", "helipad", "seaplane_base", "unknown_landing_area"]},
    "icao": {"type": ["string", "null"]},
    "faa_lid": {"type": ["string", "null"]},
    "local_code": {"type": ["string", "null"]},
    "name": {"type": "string", "minLength": 1},
    "municipio": {"type": ["string", "null"]},
    "lat": {"type": "number", "minimum": -90, "maximum": 90},
    "lon": {"type": "number", "minimum": -180, "maximum": 180},
    "geometry": {"type": ["object", "null"]},
    "geometry_status": {"type": "string", "enum": ["point_verified", "polygon_verified", "approximate", "unknown"]},
    "access_status": {"type": "string", "enum": ["public", "private", "restricted", "military", "unknown"]},
    "owner_operator": {"type": ["string", "null"]},
    "source_tier": {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "source_ref": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "review_status": {"type": "string", "enum": ["draft", "needs_review", "reviewed", "promoted", "rejected"]},
    "notes": {"type": ["string", "null"]}
  }
}
