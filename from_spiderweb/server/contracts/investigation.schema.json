{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "investigation.schema.json",
  "title": "Investigation",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["open", "closed"] },
    "created_at": { "$ref": "common.defs.schema.json#/definitions/Timestamp" },
    "updated_at": { "$ref": "common.defs.schema.json#/definitions/Timestamp" }
  },
  "required": ["id", "title", "status", "created_at"]
}