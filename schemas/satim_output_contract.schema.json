{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jotaele44/skywatcher-pr/schemas/satim_output_contract.schema.json",
  "title": "SATIM Output Contract",
  "description": "Abstract envelope for a SATIM (terrain/imagery) analysis output. Terrain/imagery-context fields only — no callsign, track, or flight-behavior fields. See docs/MODULE_SPEC_SATIM.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "satim_output_id",
    "signal_domain",
    "observation_type",
    "lat",
    "lon",
    "evidence_tier",
    "confidence",
    "geometry_status",
    "source_layer"
  ],
  "properties": {
    "satim_output_id": {"type": "string", "minLength": 1},
    "signal_domain": {"const": "terrain_imagery"},
    "observation_type": {
      "type": "string",
      "enum": ["road", "clearing", "structure", "pond", "linear_feature", "vegetation_pattern", "access_pattern", "tile_seam", "ui_overlay", "zoom_blur", "shadow_confusion", "unknown"]
    },
    "lat": {"type": "number", "minimum": -90, "maximum": 90},
    "lon": {"type": "number", "minimum": -180, "maximum": 180},
    "evidence_tier": {"type": "string", "enum": ["T1", "T2", "T3", "T4"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "geometry_status": {"type": "string", "enum": ["located", "approximate", "unlocated", "invalid"]},
    "source_layer": {"type": "string", "minLength": 1},
    "notes": {"type": ["string", "null"]}
  }
}
