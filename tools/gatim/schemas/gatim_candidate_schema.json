{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GATIM Candidate v1",
  "type": "object",
  "required": [
    "gatim_id",
    "source_dataset",
    "source_row",
    "title",
    "lat",
    "lon",
    "coord_status",
    "class_primary",
    "evidence_tier",
    "grid_id",
    "confidence",
    "review_priority"
  ],
  "properties": {
    "gatim_id": {"type": "string"},
    "source_file": {"type": "string"},
    "source_dataset": {"type": "string"},
    "source_row": {"type": ["integer", "string"]},
    "title": {"type": "string"},
    "note": {"type": "string"},
    "url": {"type": "string"},
    "tags": {"type": "string"},
    "comment": {"type": "string"},
    "lat": {"type": "string"},
    "lon": {"type": "string"},
    "coord_status": {"enum": ["direct", "needs_geocode", "missing"]},
    "dedupe_cluster_id": {"type": "string"},
    "dedupe_cluster_size": {"type": "string"},
    "class_primary": {"enum": ["ILAP", "ACCESS", "INFRASTRUCTURE", "TERRAIN_ANOMALY", "UAP_CASE_ANCHOR"]},
    "evidence_tier": {"enum": ["T1", "T2", "T3", "T4", ""]},
    "visual_features": {"type": "string"},
    "grid_id": {"type": "string"},
    "satim_link_status": {"type": "string"},
    "review_priority": {"type": "string"},
    "confidence": {"type": "string"},
    "normalization_notes": {"type": "string"}
  },
  "additionalProperties": true
}
