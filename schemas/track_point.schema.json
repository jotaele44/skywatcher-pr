{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skywatcher-pr.local/schemas/track_point.schema.json",
  "title": "Skywatcher Track Point",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "track_point_id",
    "aircraft_id",
    "observed_at_utc",
    "lat",
    "lon",
    "measurement_status",
    "provenance",
    "synthetic"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "track_point_id": {
      "type": "string",
      "minLength": 1
    },
    "flight_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "aircraft_id": {
      "type": "string",
      "minLength": 1
    },
    "observed_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90
    },
    "lon": {
      "type": "number",
      "minimum": -180,
      "maximum": 180
    },
    "barometric_altitude_ft": {
      "type": [
        "number",
        "null"
      ]
    },
    "ground_speed_kt": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "vertical_rate_fpm": {
      "type": [
        "number",
        "null"
      ]
    },
    "track_deg": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 360
    },
    "measurement_status": {
      "type": "string",
      "enum": [
        "measured",
        "derived_from_screenshot",
        "interpolated_for_display"
      ]
    },
    "interpolation_parent_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 2
    },
    "segment_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "gap_before_seconds": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "uncertainty_m": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "provenance": {
      "$ref": "source_taxonomy.schema.json"
    },
    "synthetic": {
      "type": "boolean"
    }
  }
}
