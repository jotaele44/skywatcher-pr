{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jotaele44/skywatcher-pr/schemas/flight_event.schema.json",
  "title": "Skywatcher Flight Event",
  "type": "object",
  "required": [
    "event_id",
    "source_packet",
    "source_app",
    "observed_timestamp_local",
    "observed_timestamp_utc",
    "aircraft_label",
    "geographic_context",
    "evidence_tier",
    "confidence",
    "qa_flags"
  ],
  "properties": {
    "event_id": {"type": "string"},
    "source_packet": {"type": "string"},
    "source_app": {"type": "string"},
    "observed_timestamp_local": {"type": "string"},
    "observed_timestamp_utc": {"type": "string"},
    "aircraft_label": {"type": ["string", "null"]},
    "registration": {"type": ["string", "null"]},
    "callsign": {"type": ["string", "null"]},
    "route_summary": {"type": ["string", "null"]},
    "geographic_context": {"type": "string"},
    "page_refs": {"type": "array", "items": {"type": "integer"}},
    "evidence_tier": {"enum": ["T1", "T2", "T3", "T4"]},
    "confidence": {"enum": ["low", "medium", "high"]},
    "qa_flags": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": ["string", "null"]}
  }
}
