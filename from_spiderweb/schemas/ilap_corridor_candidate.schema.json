{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ilap_corridor_candidate",
  "title": "ILAP Corridor Candidate",
  "type": "object",
  "required": ["candidate_id", "corridor_type", "origin", "destination", "confidence"],
  "properties": {
    "candidate_id":   {"type": "string", "minLength": 1},
    "corridor_type":  {
      "type": "string",
      "enum": ["point_to_point", "patrol", "survey", "hub_spoke", "unknown"]
    },
    "origin": {
      "type": "object",
      "required": ["lat", "lon"],
      "properties": {
        "lat":   {"type": "number", "minimum": -90,  "maximum": 90},
        "lon":   {"type": "number", "minimum": -180, "maximum": 180},
        "label": {"type": ["string", "null"]}
      }
    },
    "destination": {
      "type": "object",
      "required": ["lat", "lon"],
      "properties": {
        "lat":   {"type": "number", "minimum": -90,  "maximum": 90},
        "lon":   {"type": "number", "minimum": -180, "maximum": 180},
        "label": {"type": ["string", "null"]}
      }
    },
    "confidence":     {"type": "number", "minimum": 0, "maximum": 1},
    "flight_count":   {"type": ["integer", "null"], "minimum": 1},
    "callsigns":      {"type": "array", "items": {"type": "string"}},
    "distance_nm":    {"type": ["number", "null"], "minimum": 0},
    "notes":          {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
