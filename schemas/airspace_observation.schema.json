{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://priis.local/schemas/airspace_observation.schema.json",
  "title": "PRIIS Airspace Observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observation_id",
    "event_datetime",
    "lat",
    "lon",
    "signal_type",
    "source_id",
    "source_type",
    "evidence_tier",
    "confidence",
    "geometry_status",
    "temporal_status",
    "lineage_id",
    "synthetic"
  ],
  "properties": {
    "observation_id": {
      "type": "string",
      "minLength": 1
    },
    "event_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "location_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "municipality": {
      "type": [
        "string",
        "null"
      ]
    },
    "lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90
    },
    "lon": {
      "type": "number",
      "minimum": -180,
      "maximum": 180
    },
    "altitude_ft": {
      "type": [
        "number",
        "null"
      ]
    },
    "bearing": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 360
    },
    "duration_seconds": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "signal_type": {
      "type": "string",
      "minLength": 1
    },
    "description_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "screenshot",
        "adsb",
        "radar",
        "official",
        "field_note",
        "secondary"
      ],
      "deprecated": true,
      "description": "Legacy broad source value retained for reversible compatibility. New consumers use the additive canonical source dimensions."
    },
    "source_family": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "operational_position",
        "screenshot_evidence",
        "official_record",
        "manual_field",
        "secondary_reference",
        "synthetic_test",
        "unknown",
        null
      ]
    },
    "source_provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_method": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "adsb",
        "mlat",
        "satellite_adsb",
        "radar",
        "uat",
        "flarm",
        "screenshot_ocr",
        "manual_entry",
        "registry_match",
        "official_feed",
        "derived_fusion",
        "secondary_report",
        "unknown",
        "screenshot_inventory",
        "review_queue",
        "aircraft_registry",
        "track_extraction",
        "airport_operations",
        "database_import",
        null
      ]
    },
    "data_rights": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "owned",
        "licensed",
        "public_official",
        "user_supplied",
        "derived",
        "synthetic",
        "unknown",
        null
      ]
    },
    "operational_mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "live",
        "delayed",
        "historical",
        "batch",
        "evidence_only",
        "unknown",
        null
      ]
    },
    "source_record_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_taxonomy_version": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "0.1.0",
        "0.2.0",
        null
      ]
    },
    "evidence_tier": {
      "type": "string",
      "enum": [
        "T1",
        "T2",
        "T3",
        "T4"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "geometry_status": {
      "type": "string",
      "enum": [
        "located",
        "approximate",
        "unlocated",
        "invalid"
      ]
    },
    "temporal_status": {
      "type": "string",
      "enum": [
        "exact",
        "approximate",
        "missing",
        "invalid"
      ]
    },
    "lineage_id": {
      "type": "string",
      "minLength": 1
    },
    "synthetic": {
      "type": "boolean"
    },
    "qa_flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
