{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skywatcher-pr.local/schemas/maritime_baseline.schema.json",
  "title": "Skywatcher Maritime Baseline Record",
  "type": "object",
  "additionalProperties": true,
  "required": ["record_id", "source", "source_tier", "mode", "observed_at", "lat", "lon", "category", "confidence", "operational_use_allowed"],
  "properties": {
    "record_id": {"type": "string"},
    "source": {"type": "string"},
    "source_tier": {"enum": ["T1", "T2", "T3", "T4"]},
    "mode": {"enum": ["historical_baseline", "periodic_context", "batch_file"]},
    "observed_at": {"type": "string", "format": "date-time"},
    "lat": {"type": "number", "minimum": -90, "maximum": 90},
    "lon": {"type": "number", "minimum": -180, "maximum": 180},
    "category": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "operational_use_allowed": {"const": false}
  }
}
