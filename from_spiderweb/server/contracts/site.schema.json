{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "site.schema.json",
  "title": "Site",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "$ref": "common.defs.schema.json#/definitions/NonEmptyString"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "description": {
      "type": ["string", "null"]
    }
  },
  "required": ["id", "name", "latitude", "longitude"]
}