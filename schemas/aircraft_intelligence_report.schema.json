{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aircraft_intelligence_report",
  "title": "Aircraft Intelligence Report",
  "type": "object",
  "required": ["callsign", "data_source", "confidence_level"],
  "properties": {
    "callsign":          {"type": "string", "minLength": 1},
    "aircraft_type":     {"type": ["string", "null"]},
    "owner":             {"type": ["string", "null"]},
    "operator":          {"type": ["string", "null"]},
    "primary_mission":   {"type": ["string", "null"]},
    "secondary_missions":{"type": "array", "items": {"type": "string"}},
    "confidence_level":  {"type": "number", "minimum": 0, "maximum": 1},
    "data_source":       {"type": "string", "enum": ["known_db", "deduced", "db_history", "unknown"]},
    "total_flights":     {"type": ["integer", "null"], "minimum": 0},
    "first_seen":        {"type": ["string", "null"]},
    "last_seen":         {"type": ["string", "null"]},
    "operational_patterns": {"type": ["object", "null"]},
    "generated_at":      {"type": ["string", "null"]},
    "profile_completeness": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
  },
  "additionalProperties": true
}
