{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/components/**/*.js",
    "src/components/console/**/*.jsx",
    "src/components/skywatcher/Layout.jsx",
    "src/components/skywatcher/Sidebar.jsx",
    "src/pages/**/*.jsx",
    "src/App.jsx",
    "src/lib/SkywatcherData.jsx",
    "src/Layout.jsx"
  ],
  "exclude": ["node_modules", "dist", "src/vite-plugins", "src/components/ui", "src/api", "tests", "e2e"]
}
