{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "anomaly",
  "type": "object",
  "required": ["alert_id", "callsign", "severity"],
  "properties": {
    "alert_id":           {"type": "string", "minLength": 1},
    "flight_id":          {"type": ["string", "null"]},
    "callsign":           {"type": "string", "minLength": 1},
    "category":           {"type": ["string", "null"]},
    "severity":           {"type": "string", "enum": ["INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "title":              {"type": ["string", "null"]},
    "description":        {"type": ["string", "null"]},
    "evidence":           {"type": ["string", "null"]},
    "timestamp":          {"type": ["string", "null"]},
    "recommended_action": {"type": ["string", "null"]},
    "auto_resolved":      {"type": ["integer", "boolean", "null"]},
    "acknowledged":       {"type": ["integer", "boolean", "null"]},
    "created_at":         {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
