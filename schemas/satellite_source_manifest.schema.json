{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "satellite_source_manifest",
  "title": "Satellite Source Manifest",
  "type": "object",
  "required": [
    "manifest_id",
    "schema_version",
    "producer",
    "created_at",
    "synthetic",
    "source",
    "acquisition",
    "asset",
    "geometry",
    "puerto_rico",
    "quality",
    "lineage"
  ],
  "properties": {
    "manifest_id":    {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+$"},
    "producer":       {"type": "string", "minLength": 1},
    "created_at":     {"type": "string", "minLength": 1},
    "synthetic":      {"type": "boolean"},
    "notes":          {"type": ["string", "null"]},

    "source": {
      "type": "object",
      "required": ["provider", "collection", "platform", "instrument"],
      "properties": {
        "provider":   {"type": "string", "minLength": 1},
        "collection": {"type": "string", "minLength": 1},
        "platform":   {"type": "string", "minLength": 1},
        "instrument": {"type": "string", "minLength": 1}
      }
    },

    "acquisition": {
      "type": "object",
      "required": ["acquired_at", "processed_at", "license"],
      "properties": {
        "acquired_at":  {"type": "string", "minLength": 1},
        "processed_at": {"type": "string", "minLength": 1},
        "license":      {"type": "string", "minLength": 1},
        "sensor_mode":  {"type": ["string", "null"]}
      }
    },

    "asset": {
      "type": "object",
      "required": ["checksum_sha256", "media_type"],
      "anyOf": [
        {"required": ["source_uri"]},
        {"required": ["local_path"]}
      ],
      "properties": {
        "source_uri":      {"type": "string", "minLength": 1},
        "local_path":      {"type": "string", "minLength": 1},
        "checksum_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "media_type":      {"type": "string", "minLength": 1}
      }
    },

    "geometry": {
      "type": "object",
      "required": ["crs", "footprint", "bbox"],
      "properties": {
        "crs": {"type": "string", "enum": ["EPSG:4326"]},
        "footprint": {
          "type": "object",
          "required": ["type", "coordinates"],
          "properties": {
            "type": {"type": "string", "enum": ["Polygon"]},
            "coordinates": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "array",
                "minItems": 4,
                "items": {"$ref": "#/definitions/prCoordinate"}
              }
            }
          }
        },
        "bbox": {"$ref": "#/definitions/prBbox"}
      }
    },

    "puerto_rico": {
      "type": "object",
      "required": ["region"],
      "properties": {
        "region": {
          "type": "string",
          "enum": ["mainland", "vieques", "culebra", "mona", "isla_grande", "full_island"]
        },
        "municipality": {"type": ["string", "null"]}
      }
    },

    "quality": {
      "type": "object",
      "required": ["cloud_cover_pct", "geometric_confidence", "source_reliability"],
      "properties": {
        "cloud_cover_pct":      {"type": "number", "minimum": 0, "maximum": 100},
        "geometric_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "source_reliability":   {
          "type": "string",
          "enum": ["high", "medium", "low", "unverified"]
        },
        "resolution_m":         {"type": ["number", "null"], "exclusiveMinimum": 0}
      }
    },

    "terrain": {
      "type": "object",
      "properties": {
        "min_elevation_m":  {"type": "number"},
        "max_elevation_m":  {"type": "number"},
        "mean_elevation_m": {"type": "number"},
        "std_elevation_m":  {"type": "number", "minimum": 0},
        "data_source":      {"type": "string", "minLength": 1}
      }
    },

    "lineage": {
      "type": "object",
      "required": ["processing_pipeline"],
      "properties": {
        "processing_pipeline": {"type": "string", "minLength": 1},
        "pipeline_version":    {"type": ["string", "null"]},
        "derived_from":        {"type": "array", "items": {"type": "string"}}
      }
    }
  },

  "if": {
    "properties": {"synthetic": {"const": false}},
    "required": ["synthetic"]
  },
  "then": {
    "properties": {
      "asset": {
        "properties": {
          "source_uri": {"not": {"pattern": "(?i)(fixture|test|mock)"}},
          "local_path":  {"not": {"pattern": "(?i)(fixture|test|mock)"}}
        }
      }
    }
  },

  "definitions": {
    "longitude": {"type": "number", "minimum": -68.2, "maximum": -65.1},
    "latitude":  {"type": "number", "minimum": 17.8,  "maximum": 18.7},
    "prCoordinate": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": [
        {"$ref": "#/definitions/longitude"},
        {"$ref": "#/definitions/latitude"}
      ]
    },
    "prBbox": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": [
        {"$ref": "#/definitions/longitude"},
        {"$ref": "#/definitions/latitude"},
        {"$ref": "#/definitions/longitude"},
        {"$ref": "#/definitions/latitude"}
      ]
    }
  },

  "additionalProperties": true
}
