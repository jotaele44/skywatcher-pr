# Example environment configuration. Copy to `.env` and fill in real values.
# NEVER commit a real `.env` (it is gitignored). No production credentials live
# in this repository.

# ── Imagery MCP server (requirements-imagery.txt) ────────────────────────────
# Satellite imagery providers. GIBS needs no credentials; the others use OAuth2
# client-credentials. Leave blank to disable a provider.
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
# Optional overrides (see imagery/config.py for the full list):
# IMAGERY_DEFAULT_PROVIDER=gibs
# IMAGERY_CACHE_DIR=tile_cache/imagery
# IMAGERY_BUFFER_DEG=0.05
# IMAGERY_IMAGE_SIZE=512
