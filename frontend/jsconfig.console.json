{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/api/federationClient": ["./types/console-federation-client.d.ts"],
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/components/console/**/*.js",
    "src/components/console/**/*.jsx",
    "src/pages/AirspaceConsole.jsx",
    "types/console-federation-client.d.ts"
  ],
  "exclude": ["node_modules", "dist", "tests", "e2e"]
}
