{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skywatcher-pr.local/schemas/cross_domain_overlap.schema.json",
  "title": "Skywatcher Cross-Domain Overlap",
  "type": "object",
  "additionalProperties": true,
  "required": ["overlap_id", "air_event_ids", "maritime_record_ids", "corridor_id", "time_window_minutes", "distance_km", "confidence", "explanation"],
  "properties": {
    "overlap_id": {"type": "string"},
    "air_event_ids": {"type": "array", "items": {"type": "string"}},
    "maritime_record_ids": {"type": "array", "items": {"type": "string"}},
    "corridor_id": {"type": "string"},
    "time_window_minutes": {"type": "number", "minimum": 0},
    "distance_km": {"type": "number", "minimum": 0},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "explanation": {"type": "string", "minLength": 1}
  }
}
