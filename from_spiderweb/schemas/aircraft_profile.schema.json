{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aircraft_profile",
  "type": "object",
  "required": ["callsign"],
  "properties": {
    "callsign":          {"type": "string", "minLength": 1},
    "aircraft_type":     {"type": ["string", "null"]},
    "owner":             {"type": ["string", "null"]},
    "operator":          {"type": ["string", "null"]},
    "primary_mission":   {"type": ["string", "null"]},
    "confidence_level":  {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "data_source":       {"type": ["string", "null"]},
    "last_seen":         {"type": ["string", "null"]},
    "flight_count":      {"type": ["integer", "null"], "minimum": 0}
  },
  "additionalProperties": true
}
