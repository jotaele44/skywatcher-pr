{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://satim.local/schemas/satim_provider_profile_v1.schema.json",
  "title": "SATIM Provider Profile v1",
  "type": "object",
  "required": ["profile_id", "version", "provider", "source_types", "measurement_definitions", "class_thresholds", "status", "checksum_sha256"],
  "properties": {
    "profile_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "product_or_sensor": {"type": ["string", "null"]},
    "source_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["raw_scene", "orthophoto", "web_tile", "screenshot", "pdf_frame", "unknown"]}},
    "gsd_min_m": {"type": ["number", "null"], "minimum": 0},
    "gsd_max_m": {"type": ["number", "null"], "minimum": 0},
    "zoom_min": {"type": ["integer", "null"]},
    "zoom_max": {"type": ["integer", "null"]},
    "measurement_definitions": {"type": "object"},
    "class_thresholds": {"type": "object"},
    "calibration_dataset_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "status": {"enum": ["experimental", "validated", "deprecated"]},
    "created_at": {"type": ["string", "null"], "format": "date-time"},
    "checksum_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
